# Backend API base URL, including the /api/v1 prefix.
# Dev default (when unset): http://localhost:8000/api/v1
VITE_API_BASE_URL=https://api.cuaworld.vibrantlabs.com/api/v1

# Offline mode (dev only): read runs straight from the repo's outputs/ with no
# backend and no login. Uncomment for local viewing without the hosted service.
# VITE_DATA_SOURCE=local
